@startuml GreenEcoCommerce_UseCase_Overview_v1.3.0
left to right direction

' Cấu hình giao diện
skinparam packageStyle rectangle
skinparam UseCaseBackgroundColor #F9F9F9
skinparam UseCaseBorderColor #2E8B57
skinparam ActorBorderColor #2E8B57
skinparam ArrowColor #4A708B

actor "Người dùng" as User
actor "Quản trị viên" as Admin

rectangle "GreenEcoCommerce" {

  ' --- DÒNG 1 ---
  package "Quản lý Tài khoản" as P_Account {
    usecase "Đăng ký" as UC_Reg
    usecase "Đăng nhập" as UC_Login
    usecase "Xem trang cá nhân" as UC_ViewResume
  }

  package "Quản lý Sản phẩm & Danh mục" as P_Product {
    usecase "Xem danh sách sản phẩm" as UC_ViewListProduct
    usecase "Xem chi tiết sản phẩm" as UC_ViewDetailProduct
    usecase "Tìm kiếm sản phẩm" as UC_SearchProduct
    usecase "Quản lý sản phẩm (CRUD)" as UC_ManageProduct
    usecase "Quản lý danh mục (CRUD)" as UC_ManageCategory
  }

  ' --- DÒNG 2 ---
  package "Quản lý Giỏ hàng & Đặt hàng" as P_Order {
    usecase "Quản lý Sản phẩm trong Giỏ hàng (CRUD)" as UC_ManageProductCart
    usecase "Nhập địa chỉ giao hàng" as UC_ProvideAddress
    usecase "Chuyển khoản" as UC_Transfer
    usecase "Cập nhật trạng thái đơn hàng" as UC_UpdateOrderStatus
    usecase "Xem lịch sử mua hàng" as UC_ViewOrderHistory
  }

  package "Quản lý điểm xanh" as P_GreenPoint {
    usecase "Xem điểm xanh" as UC_ViewGreenPoint
    usecase "Đổi voucher" as UC_ExchangeVoucher
  }

  ' --- DÒNG 3 ---
  package "Chatbot & RAG" as P_Chatbot {
    usecase "Trò chuyện với Chatbot" as UC_CommunicateChatbot
    usecase "Upload Cơ sở tri thức cho Chatbot" as UC_UploadKnowledgeBaseDocument
  }

  package "Thống kê & Báo cáo" as P_Report {
    usecase "Xem Dashboard" as UC_ViewDashboard
    usecase "Xuất dữ liệu thống kê" as UC_ExportDataFile
  }

  ' --------------------------------------------------
  ' THIẾT LẬP LAYOUT: Ép các package xuống dòng theo cặp
  ' --------------------------------------------------
  P_Account -[hidden]down-> P_Order
  P_Order -[hidden]down-> P_Chatbot
}

' -----------------------------------
' KẾT NỐI CỦA NGƯỜI DÙNG (BÊN TRÁI)
' -----------------------------------
User --> UC_Reg
User --> UC_Login
User --> UC_ViewResume

User --> UC_ViewListProduct
User --> UC_ViewDetailProduct
User --> UC_SearchProduct

User --> UC_ManageProductCart
User --> UC_ProvideAddress
User --> UC_Transfer
User --> UC_ViewOrderHistory

User --> UC_ViewGreenPoint
User --> UC_ExchangeVoucher
User --> UC_CommunicateChatbot

' -----------------------------------
' KẾT NỐI CỦA QUẢN TRỊ VIÊN (BÊN PHẢI)
' -----------------------------------
UC_Login <-- Admin
UC_ManageProduct <-- Admin
UC_ManageCategory <-- Admin
UC_UpdateOrderStatus <-- Admin
UC_UploadKnowledgeBaseDocument <-- Admin
UC_ViewDashboard <-- Admin
UC_ExportDataFile <-- Admin

@enduml
