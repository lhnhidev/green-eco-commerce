@startuml GreenEcoCommerce_UseCase_GreenPoint_v1.0.0
left to right direction

' Cấu hình giao diện
skinparam packageStyle rectangle
skinparam UseCaseBackgroundColor #F9F9F9
skinparam UseCaseBorderColor #2E8B57
skinparam ActorBorderColor #2E8B57
skinparam ArrowColor #4A708B

actor "Người dùng" as User

rectangle "Quản lý Điểm xanh" {
  usecase "Xem điểm xanh" as UC_ViewGreenPoint
  usecase "Đổi voucher" as UC_ExchageVoucher
  usecase "Cập nhật điểm số tự động" as UC_UpdatePointAutomationally
}

User --> UC_ViewGreenPoint
User --> UC_ExchageVoucher
UC_ExchageVoucher --> UC_UpdatePointAutomationally

@enduml
