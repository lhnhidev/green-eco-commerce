@startuml GreenEcoCommerce_UseCase_Overview_v1.1.0
left to right direction
skinparam packageStyle rectangle
skinparam UseCaseBackgroundColor #F9F9F9
skinparam UseCaseBorderColor #2E8B57
skinparam ActorBorderColor #2E8B57

actor "Người dùng" as User
actor "Quản trị viên" as Admin

rectangle "GreenEcoCommerce" {

  package "Quản lý Tài khoản" {
    usecase "Đăng ký" as UC_Reg
    usecase "Đăng nhập" as UC_Login
    usecase "Xem trang cá nhân" as UC_ViewResume
  }

  package "Quản lý Sản phẩm & Danh mục" {
    usecase "Xem danh sách sản phẩm" as UC_ViewListProduct
    usecase "Xem chi tiết sản phẩm" as UC_ViewDetailProduct
    usecase "Tìm kiếm sản phẩm" as UC_SearchProduct
    usecase "Quản lý sản phẩm (CRUD)" as UC_ManageProduct
    usecase "Quản lý danh mục (CRUD)" as UC_ManageCategory
  }

  package "Quản lý Giỏ hàng & Đặt hàng" {
    usecase "Quản lý Sản phẩm trong Giỏ hàng (CRUD)" as UC_ManageProductCategory
    usecase "Nhập địa chỉ giao hàng" as UC_ProvideAddress
    usecase "Chuyển khoản" as UC_Transfer
    usecase "Cập nhật trạng thái đơn hàng" as UC_UpdateOrderStatus
    usecase "Xem lịch sử mua hàng" as UC_ViewOrderHistory
  }

  package "Quản lý điểm xanh" {
    usecase "Xem điểm xanh" as UC_ViewGreenPoint
    usecase "Đổi voucher" as UC_ExchangeVoucher
  }

  package "Chatbot & RAG" {
    usecase "Trò chuyện với Chatbot" as UC_CommunicateChatbot
    usecase "Upload Cơ sở tri thức cho Chatbot" as UC_UploadKnowledgeBaseDocument
  }

  package "Thống kê & Báo cáo" {
    usecase "Xem Dashboard" as UC_ViewDashboard
    usecase "Xuất dữ liệu thống kê" as UC_ExportDataFile
  }

}



@enduml
