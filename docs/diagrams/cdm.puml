@startuml CDM
!theme plain
hide circle

' ================= ENTITIES =================

entity "USER" as user #E8F4FF {
  * id : PK
  --
  email
  password_hash
  full_name
  phone
  role (user/admin)
  created_at
}

entity "CATEGORY" as category #E8F8F5 {
  * id : PK
  --
  name
  slug
  description
  parent_id : FK
}

entity "PRODUCT" as product #E9F7EF {
  * id : PK
  --
  name
  slug
  description
  price
  stock_qty
  carbon_index
  material_origin
  decompose_percent
  recycle_percent
  category_id : FK
}

entity "PRODUCT_IMAGE" as product_image #F2F3F4 {
  * id : PK
  --
  product_id : FK
  azure_url
  is_primary
}

entity "CART" as cart #FEF9E7 {
  * id : PK
  --
  user_id : FK
  updated_at
}

entity "CART_ITEM" as cart_item #FEF9E7 {
  * id : PK
  --
  cart_id : FK
  product_id : FK
  quantity
}

entity "ORDER" as order #FDEDEC {
  * id : PK
  --
  user_id : FK
  status
  delivery_address
  total_amount
  total_co2_saved
  created_at
}

entity "ORDER_ITEM" as order_item #FDEDEC {
  * id : PK
  --
  order_id : FK
  product_id : FK
  quantity
  unit_price
}

entity "PAYMENT" as payment #F2F3F4 {
  * id : PK
  --
  order_id : FK
  method (bank_transfer)
  status
  amount
  transaction_ref
}

entity "GREEN_POINT" as green_point #E9F7EF {
  * id : PK
  --
  user_id : FK
  balance
  earned_total
  updated_at
}

entity "VOUCHER" as voucher #E9F7EF {
  * id : PK
  --
  code
  discount_value
  points_cost
  expires_at
  is_used
}

entity "CHAT_SESSION" as chat_session #F4ECF7 {
  * id : PK
  --
  user_id : FK
  created_at
}

entity "CHAT_MESSAGE" as chat_message #F4ECF7 {
  * id : PK
  --
  session_id : FK
  role (user/assistant)
  content
  timestamp
}

entity "DOCUMENT" as document #F2F3F4 {
  * id : PK
  --
  file_name
  file_type
  azure_url
  uploaded_by : FK
}

entity "EMBEDDING" as embedding #F2F3F4 {
  * id : PK
  --
  document_id : FK
  chunk_text
  vector_id (Pinecone)
}

' ================= RELATIONSHIPS =================

' Người dùng và Giỏ hàng
user ||--|| cart : 1-1
cart ||--o{ cart_item : 1-N

' Sản phẩm và Danh mục
category |o--o{ category : 1-N (self)
category ||--o{ product : 1-N
product ||--o{ product_image : 1-N
product ||--o{ cart_item : 1-N

' Đơn hàng và Thanh toán
user ||--o{ order : 1-N
order ||--o{ order_item : 1-N
product ||--o{ order_item : 1-N
order ||--|| payment : 1-1

' Tích điểm xanh (Green/Eco)
user ||--|| green_point : 1-1
green_point ||--o{ voucher : 1-N

' AI Chat & RAG
user ||--o{ chat_session : 1-N
chat_session ||--o{ chat_message : 1-N
user ||--o{ document : 1-N
document ||--o{ embedding : 1-N

@enduml
