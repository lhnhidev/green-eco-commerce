  @startuml GreenEcoCommerce_UseCase_Detail_v1.0.0
  left to right direction

  actor "Khách hàng (User)" as User
  actor "Quản trị viên (Admin)" as Admin

  rectangle "Phân hệ Khách hàng & Chatbot" {
      usecase "Xem chi tiết sản phẩm" as UC_ViewDetail
      usecase "Lọc theo độ ưu tiên môi trường" as UC_Filter

      usecase "Đặt hàng & Thanh toán" as UC_Checkout
      usecase "Nhập địa chỉ qua Google Map" as UC_Map
      usecase "Chuyển khoản ngân hàng" as UC_Bank

      usecase "Trò chuyện với Chatbot" as UC_Chat
      usecase "Tính toán dấu chân Carbon" as UC_Carbon
      usecase "Gợi ý sản phẩm bằng AI" as UC_Rec
      usecase "Tra cứu tài liệu (RAG)" as UC_RAG
  }

  rectangle "Phân hệ Quản trị (Admin)" {
      usecase "Quản lý sản phẩm" as UC_CRUD_Prod
      usecase "Upload ảnh lên Azure" as UC_UploadAzure
      usecase "Upload tài liệu PDF/Docx" as UC_UploadDoc
  }

  UC_ViewDetail <.. UC_Filter : <<extend>>
  User --> UC_ViewDetail
  User --> UC_Checkout
  UC_Checkout ..> UC_Map : <<include>>
  UC_Checkout ..> UC_Bank : <<include>>

  User --> UC_Chat
  UC_Chat <.. UC_Carbon : <<extend>>
  UC_Chat <.. UC_Rec : <<extend>>
  UC_Chat <.. UC_RAG : <<extend>>

  Admin --> UC_CRUD_Prod
  UC_CRUD_Prod ..> UC_UploadAzure : <<include>>
  Admin --> UC_UploadDoc
  @startuml
